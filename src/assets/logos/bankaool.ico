                                        </div>
                                    </div>
                                    <div class="col-md-6 col-lg-2 mb-3 mb-md-0">
                                        <div class="list-group list-group-flush">
                                            <h6 class="text-dark" style="font-size: 18px; font-family: poppins-bold">Seguros</h6>
                                            <a href="/personas/seguro-de-vida" class="list-group-item list-group-item-action">Seguro de vida</a>
