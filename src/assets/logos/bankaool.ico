        <script type="text/javascript" src="js/jquery.min.js"></script>
        <script type="text/javascript" src="js/mdb.min.js"></script>
        <script type="text/javascript" src="FontAwesome/js/all.js"></script>
        <script type="text/javascript" src="js/toastr.min.js"></script>
        <script type="text/javascript" src="js/scripts.js"></script>
        <script src="/webflow/Legales/js/aclaraciones-api.js" type="text/javascript"></script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
        <script>

            $(document).ready(function () {
                $('ul.navbar-nav #li-persona.dropdown').hover(function () {
                    $(this).find('.nav-link').css('font-family', 'poppins-bold').delay(200).fadeIn(200);
                    $(this).find('.dropdown-menu').stop(true, true).delay(100).fadeIn(100);
                    $('body').eq(0).css({ "overflow": "hidden" });
                }, function () {
                    $(this).find('.nav-link').css('font-family', 'poppins').delay(200).fadeIn(200);
                    $(this).find('.dropdown-menu').stop(true, true).delay(100).fadeOut(100);
                    $('body').eq(0).css({ "overflow": "auto" });
                });

                $('ul.navbar-nav #li-empresa.dropdown').hover(function () {
                    $(this).find('.dropdown-menu').stop(true, true).delay(0).fadeIn(100);
                    $('#navbar').addClass('bg-dark-primary');
                    $(this).find('.nav-link').addClass('text-white').delay(200).fadeIn(200);
                    $(this).find('.nav-link').css('font-family', 'poppins-bold').delay(200).fadeIn(200);
                    $('body').eq(0).css({ "overflow": "hidden" });
                    $("#imgLogo-1").attr("src", "./img/icons/logo_bankaool.svg");
                }, function () {
                    $(this).find('.nav-link').removeClass('text-white').delay(200).fadeIn(200);
                    $(this).find('.nav-link').css('font-family', 'poppins').delay(200).fadeIn(200);
                    $(this).find('.dropdown-menu').stop(true, true).delay(0).fadeOut(100);
                    $('#navbar').removeClass('bg-dark-primary');
                    $('body').eq(0).css({ "overflow": "auto" });
                    $("#imgLogo-1").attr("src", "../img/logo_bankaool.svg");
                });

            });

        </script>
        <div class="modal fade" id="CondusefModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header" style="padding: 40px 32px 30px 32px; border: none;">
                        <h5 class="fw-bold">Comisión Nacional para la Protección y Defensa de los Usuarios de Servicios Financieros.
                        </h5>
                        <button type="button" class="btn-close me-1" data-mdb-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body row" style="padding: 0 32px 32px 32px">
                        <div class="mt-2">
                            <p class="sublanding-subtitle text-dark-bankaool"><b>Domicilio</b>: Avenida Insurgentes Sur No. 762, Col. Del Valle, Alcaldía Benito Juárez, Ciudad de México, C.P. 03100</p>
                            <p class="sublanding-subtitle text-dark-bankaool"><b>Teléfono</b>: <a href="tel:+5553400999" class="link-dark-bankaool">(55) 5340 0999</a></p>
                            <p class="sublanding-subtitle text-dark-bankaool"><b>Correo electrónico</b>:  <a href="mailto:asesoria@condusef.gob.mx" class="link-dark-bankaool">asesoria@condusef.gob.mx</a></p>
                            <p class="sublanding-subtitle text-dark-bankaool"><b>Sitio web</b>:  <a class="link-dark-bankaool" href="http://www.condusef.gob.mx">http://www.condusef.gob.mx </a></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="modal fade" id="MeInteresaModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header" style="padding: 32px 32px 48px 32px; border: none;">
                        <img src="img/logo_bankaool.svg" class="img-fluid logo-modal" alt="Alternate Text" />
                        <button type="button" class="btn-close me-1" data-mdb-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body row" style="padding: 0 32px 32px 32px">
                        <div class="mt-2">
                            <h3 class="sublanding-subtitle text-dark-bankaool"><b>Datos de contacto</b></h3>
                        </div>
                        <div class="col-12">
                            <input type="hidden" name="ctl00$hProducto" id="hProducto" />
                            <div class="group">
                                <input name="ctl00$iNombre" type="text" id="iNombre" />
                                <span class="highlight"></span>
                                <span class="bar"></span>
                                <label>Nombre</label>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="group">
                                <input name="ctl00$iLada" type="tel" id="iLada" maxlength="10" minlenght="10" autocomplete="off" />
                                <span class="highlight"></span>
                                <span class="bar"></span>
                                <label>Lada</label>
                            </div>
                        </div>
                        <div class="col-8">
                            <div class="group">
                                <input name="ctl00$iNumero" type="tel" id="iNumero" maxlength="10" minlenght="10" autocomplete="off" />
                                <span class="highlight"></span>
                                <span class="bar"></span>
                                <label for="iNumero">Número</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="group">
                                <select name="ctl00$Edos" id="Edos" class="form-select select-edos mb-3" style="padding: 10px 10px 10px 5px;">
	<option selected="selected" value="0">Estado</option>
	<option value="Aguascalientes">Aguascalientes</option>
	<option value="Baja California">Baja California</option>
	<option value="Baja California Sur">Baja California Sur</option>
	<option value="Campeche">Campeche</option>
	<option value="Chiapas">Chiapas</option>
	<option value="Chihuahua">Chihuahua</option>
	<option value="Ciudad de México">Ciudad de M&#233;xico</option>
	<option value="Coahuila">Coahuila</option>
	<option value="Colima">Colima</option>
	<option value="Durango">Durango</option>
	<option value="Guanajuato">Guanajuato</option>
	<option value="Guerrero">Guerrero</option>
	<option value="Hidalgo">Hidalgo</option>
	<option value="Jalisco">Jalisco</option>
	<option value="México">M&#233;xico</option>
	<option value="Michoacán">Michoac&#225;n</option>
	<option value="Morelos">Morelos</option>
	<option value="Nayarit">Nayarit</option>
	<option value="Nuevo León">Nuevo Le&#243;n</option>
	<option value="Oaxaca">Oaxaca</option>
	<option value="Puebla">Puebla</option>
	<option value="Querétaro">Quer&#233;taro</option>
	<option value="Quintana Roo">Quintana Roo</option>
	<option value="San Luis Potosí">San Luis Potos&#237;</option>
	<option value="Sinaloa">Sinaloa</option>
	<option value="Sonora">Sonora</option>
	<option value="Tabasco">Tabasco</option>
	<option value="Tamaulipas">Tamaulipas</option>
	<option value="Tlaxcala">Tlaxcala</option>
	<option value="Veracruz">Veracruz</option>
	<option value="Yucatán">Yucat&#225;n</option>
	<option value="Zacatecas">Zacatecas</option>
</select>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="group">
                                <input name="ctl00$iCorreo" type="email" id="iCorreo" autocomplete="off" />
                                <span class="highlight"></span>
                                <span class="bar"></span>
                                <label for="iNumero">Correo electrónico</label>
                            </div>
                        </div>
                        <div class="col-12 mb-4">
                            <div class="form-check">
                                <input name="ctl00$iAceptarPolitica" type="checkbox" id="iAceptarPolitica" class="form-check-input" style="border: 1px solid #141415" />
                                <label class="form-check-label text-dark-bankaool" for="iAceptarPolitica">
                                    Acepto <a class="link" href="aviso-de-privacidad" target="_blank"><b>política de privacidad</b></a>
                                </label>
                            </div>
                        </div>
                        <div class="col-12 mb-1 text-center">
                            <input type="submit" name="ctl00$ctl25" value="Enviar" class="btn btn-rounded btn-primary-bankaool m-0" style="padding: 10px 35px;" />
                        </div>

                    </div>
                </div>
            </div>
        </div>

        
    </form>
    <!-- Modal de Aclaraciones -->
    <div class="modal fade custom-modal" id="aclaracionesModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="btn-close text-white" data-bs-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <!-- Logo e Información de navegación -->
                    <div class="text-center mb-3">
                        <img src="/img/bankaool-logo-white.png" alt="Bankaool" height="50" class="mb-2">
                        <div class="aclaraciones-steps-path">
                            <span id="currentPath">Inicio</span> <span id="pathDetail"></span>
                        </div>
                    </div>

                    <!-- Vista Inicial - Opciones principales -->
                    <div id="vista-inicial" class="aclaraciones-view active">
                        <div class="d-grid gap-3 mt-4">
                            <button type="button" class="btn btn-outline-light btn-lg rounded-pill" id="btnNuevaAclaracion">
                                Nueva aclaración
                            </button>
                            <button type="button" class="btn btn-outline-light btn-lg rounded-pill" id="btnConsultarEstatus">
                                Estatus de mi aclaración
                            </button>
                        </div>
                    </div>

                    <!-- Vista Nueva Aclaración -->
                    <div id="vista-nueva-aclaracion" class="aclaraciones-view">
                        <form id="formNuevaAclaracion" class="needs-validation" novalidate>
                            <div class="mb-3">
                                <label for="idMovimiento" class="form-label">ID Movimiento</label>
                                <input type="text" class="form-control" id="idMovimiento" name="idMovimiento" placeholder="Ejemplo: 2550" required>
                                <div class="invalid-feedback">Este campo es obligatorio.</div>
                            </div>
                            <div class="mb-3">
                                <label for="phone" class="form-label">Teléfono</label>
                                <input type="tel" class="form-control" id="phone" name="phone" placeholder="Ejemplo: 6141234567" pattern="[0-9]{10}" required>
                                <div class="invalid-feedback">Ingresa un teléfono válido de 10 dígitos.</div>
                            </div>
                            <div class="mb-3">
                                <label for="email" class="form-label">Correo Electrónico</label>
                                <input type="email" class="form-control" id="email" name="email" placeholder="ejemplo@correo.com" required>
                                <div class="invalid-feedback">Ingresa un correo electrónico válido.</div>
                            </div>
                            <div class="mb-3">
                                <label for="comentario" class="form-label">Comentario</label>
                                <textarea class="form-control" id="comentario" name="comentario" rows="3" placeholder="Describe tu aclaración" required></textarea>
                                <div class="invalid-feedback">Este campo es obligatorio.</div>
                            </div>
                            <div class="d-grid gap-2 mt-4">
                                <button type="submit" class="btn btn-primary rounded-pill">Enviar Aclaración</button>
                                <button type="button" class="btn btn-outline-light rounded-pill" id="btnVolverInicio1">Cancelar</button>
                            </div>
                        </form>
                    </div>

                    <!-- Vista Consultar Estatus -->
                    <div id="vista-consultar-estatus" class="aclaraciones-view">
                        <form id="formConsultarAclaracion" class="needs-validation" novalidate>
                            <div class="mb-3">
                                <label for="folio" class="form-label">Folio aclaración</label>
                                <input type="text" class="form-control" id="folio" name="folio" placeholder="Ejemplo: CAVBA-4966" required>
                                <div class="invalid-feedback">Este campo es obligatorio.</div>
                            </div>
                            <div class="d-grid gap-2 mt-4">
                                <button type="submit" class="btn btn-primary rounded-pill">Buscar</button>
                                <button type="button" class="btn btn-outline-light rounded-pill" id="btnVolverInicio2">Cancelar</button>
                            </div>
                        </form>
                    </div>

                    <!-- Vista Resultado Nueva Aclaración -->
                    <div id="vista-resultado-aclaracion" class="aclaraciones-view text-center">
                        <h4 class="mb-3">Folio de aclaración</h4>
                        <div class="folio-result mb-3">
                            <span id="folioGenerado" class="text-primary"></span>
                        </div>
                        <p id="mensajeAclaracion" class="alert alert-warning mb-4" style="display: none;"></p>
                        <div class="d-grid">
                            <button type="button" class="btn btn-primary rounded-pill" id="btnAceptarFolio">Aceptar</button>
                        </div>
                    </div>

                    <!-- Vista Resultado Estatus -->
                    <div id="vista-resultado-estatus" class="aclaraciones-view text-center">
                        <h4 class="mb-3">Estado</h4>
                        <div class="estado-result mb-4">
                            <span id="estadoAclaracion" class="text-primary"></span>
                        </div>
                        <div class="d-grid">
                            <button type="button" class="btn btn-primary rounded-pill" id="btnAceptarEstatus">Aceptar</button>
                        </div>
                    </div>

                    <!-- Vista Error -->
                    <div id="vista-error" class="aclaraciones-view text-center">
                        <h4 class="mb-2">Ha ocurrido un error!</h4>
                        <p id="mensajeError" class="text-muted mb-4">Inténtalo nuevamente</p>
                        <div class="d-grid">
                            <button type="button" class="btn btn-outline-light rounded-pill" id="btnIntentarNuevamente">Intentar de nuevo</button>
                        </div>
                    </div>

                    <!-- Indicador de Loading -->
                    <div id="loadingIndicator" class="loading-overlay" style="display: none;">
                        <div class="spinner-border text-light" role="status">
                            <span class="visually-hidden">Cargando...</span>
                        </div>
                    </div>

                    <!-- Resultados dinámicos (para mensajes de éxito/error) -->
                    <div id="resultadoNuevaAclaracion" class="mt-3 text-center"></div>
                    <div id="resultadoConsultaAclaracion" class="mt-3 text-center"></div>
                </div>
            </div>
        </div>
    </div>
</body>


